# Firebase
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_DATABASE_URL=https://anpr-for-default-rtdb.firebaseio.com

# Meta Cloud API WhatsApp (Production)
META_WHATSAPP_TOKEN=your_meta_permanent_access_token
META_PHONE_NUMBER_ID=your_phone_number_id

# Cloudinary (for Guardian Mode images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# Server Config
HOST=0.0.0.0
PORT=8000

# Dashboard URLs (update with your dashboard laptop's address)
USER_DASHBOARD_URL=http://localhost:5174
ADMIN_DASHBOARD_URL=http://localhost:5173
